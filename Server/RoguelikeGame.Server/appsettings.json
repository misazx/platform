{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=roguelike.db"
  },
  "Jwt": {
    "Issuer": "RoguelikeGameServer",
    "Audience": "RoguelikeGameClient",
    "Key": "your_super_secret_jwt_key_here_change_in_production_at_least_32_characters!",
    "ExpireDays": 7
  },
  "ServerSettings": {
    "MaxRooms": 100,
    "MaxPlayersPerRoom": 4,
    "HeartbeatInterval": 30,
    "MatchmakingTimeout": 60
  },
  "AllowedHosts": "*"
}
